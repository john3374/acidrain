# App
NEXTAUTH_URL=http://localhost:4001
NEXTAUTH_SECRET=

# OAuth providers
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MongoDB. Prefer MONGODB_URI when available. Legacy DB_* keys are still supported.
MONGODB_URI=
MONGODB_DB=acidrain
DB_HOST=
DB_USER=
DB_PASSWORD=

# Optional X.509 auth mode. Set this only when using MongoDB X.509 credentials.
MONGODB_X509_CERTIFICATE_KEY_FILE=

# Optional browser Socket.io endpoint. Leave unset in production when /socket.io is proxied on the app host.
NEXT_PUBLIC_WEBSOCKET_URL=

# Socket.io server config.
WEBSOCKET_PORT=4000
WEBSOCKET_CORS_ORIGINS=http://localhost:4001

# Basic in-process API rate limiting. Use shared infrastructure later for multi-instance deployments.
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_MS=5000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=5000
